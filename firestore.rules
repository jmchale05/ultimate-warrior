rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────

    // Is the request from a signed-in user?
    function isAuthed() {
      return request.auth != null;
    }

    // Fetch the caller's user document (cached per request)
    function callerDoc() {
      let doc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return (doc != null) ? doc.data : {};
    }

    function callerRole() {
      return (callerDoc().role is string) ? callerDoc().role : null;
    }

    function callerSchool() {
      return (callerDoc().schoolId is string) ? callerDoc().schoolId : null;
    }

    function isAdmin() {
      return isAuthed() && callerRole() == 'admin';
    }

    function isTeacher() {
      return isAuthed() && callerRole() == 'teacher';
    }

    function isStudent() {
      return isAuthed() && callerRole() == 'student';
    }

    function sameSchool(schoolId) {
      return isAuthed() && callerSchool() != null && callerSchool() == schoolId;
    }

    function classSchoolId(classId) {
      return get(/databases/$(database)/documents/classes/$(classId)).data.schoolId;
    }

    function userSchoolId() {
      return resource.data.schoolId is string
        ? resource.data.schoolId
        : (
          resource.data.classId is string
            ? classSchoolId(resource.data.classId)
            : null
        );
    }

    function resultSchoolId() {
      return resource.data.schoolId is string
        ? resource.data.schoolId
        : (
          resource.data.classId is string
            ? classSchoolId(resource.data.classId)
            : null
        );
    }

    function requestedResultSchoolId() {
      return request.resource.data.schoolId is string
        ? request.resource.data.schoolId
        : (
          request.resource.data.classId is string
            ? classSchoolId(request.resource.data.classId)
            : null
        );
    }

    // ── /schools ─────────────────────────────────────────────────────────────
    // Admins: full access
    // Teachers/students: read only their own school document (no listing all schools)
    match /schools/{schoolId} {
      allow get: if isAuthed() && (isAdmin() || sameSchool(schoolId));
      allow list: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin() || (isTeacher() && sameSchool(schoolId));
      allow delete: if isAdmin();
    }

    match /schoolAccessCodes/{accessCode} {
      allow get: if true;
      allow list: if false;
      allow create, update, delete: if isAdmin();
    }

    // ── /users ────────────────────────────────────────────────────────────────
    // Users can read/write their own doc.
    // Teachers can read docs for students in their school.
    // Admins have full access.
    match /users/{uid} {
      allow read: if isAuthed() && (
        request.auth.uid == uid ||
        isAdmin() ||
        (isTeacher() && sameSchool(userSchoolId())) ||
        (isTeacher() && resource.data.role == 'admin')
      );
      // Allow initial self-profile creation on signup, plus teacher/admin managed creation.
      allow create: if isAuthed() && (
        (
          request.auth.uid == uid &&
          request.resource.data.uid == uid &&
          request.resource.data.email == request.auth.token.email &&
          request.resource.data.role == 'teacher' &&
          exists(/databases/$(database)/documents/schools/$(request.resource.data.schoolId))
        ) ||
        isAdmin() ||
        (isTeacher() && sameSchool(request.resource.data.schoolId))
      );
      allow update: if isAuthed() && (
        request.auth.uid == uid ||
        isAdmin() ||
        (isTeacher() && sameSchool(userSchoolId()))
      );
      allow delete: if isAdmin() || (isTeacher() && sameSchool(userSchoolId()));
    }

    // ── /classes ──────────────────────────────────────────────────────────────
    // Teachers can CRUD classes they own in their school.
    // Students can read their own class.
    // Admins have full access.
    match /classes/{classId} {
      allow read: if isAuthed() && (
        isAdmin() ||
        sameSchool(resource.data.schoolId)
      );
      allow create: if isTeacher() && sameSchool(request.resource.data.schoolId);
      allow update: if isAdmin() || (isTeacher() && sameSchool(resource.data.schoolId));
      allow delete: if isAdmin() || (isTeacher() && resource.data.teacherId == request.auth.uid);
    }

    // ── /results ──────────────────────────────────────────────────────────────
    // Students can submit their own results.
    // Teachers can read results for their school.
    // Admins have full access.
    match /results/{resultId} {
      allow read: if isAuthed() && (
        isAdmin() ||
        (isTeacher() && sameSchool(resultSchoolId())) ||
        (isStudent() && resource.data.studentId == request.auth.uid)
      );
      allow create: if isAuthed() && (
        isAdmin() ||
        (isTeacher() && sameSchool(requestedResultSchoolId())) ||
        (
          isStudent() &&
          request.resource.data.studentId == request.auth.uid &&
          sameSchool(requestedResultSchoolId())
        )
      );
      allow update: if isAdmin() || (isTeacher() && sameSchool(resultSchoolId()));
      allow delete: if isAdmin() || (isTeacher() && sameSchool(resultSchoolId()));
    }

    // ── /studentDeletionRequests ────────────────────────────────────────────
    // Teachers create requests for admin review.
    // Admins can view and manage all requests.
    match /studentDeletionRequests/{requestId} {
      allow create: if isTeacher() && sameSchool(request.resource.data.schoolId);
      allow read: if isAdmin() || (isTeacher() && sameSchool(resource.data.schoolId));
      allow update, delete: if isAdmin();
    }

    // ── /mail ───────────────────────────────────────────────────────────────
    // Outbound email queue documents (e.g. Firebase Trigger Email extension).
    match /mail/{mailId} {
      allow create: if isAdmin() || isTeacher();
      allow read, update, delete: if isAdmin();
    }
  }
}
