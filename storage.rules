rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ── Profile photos ────────────────────────────────────────────────────────
    // Only the owner or a teacher in the same school can write.
    // Read access is restricted to the owner, admins, or teachers in the same school.
    match /profile-photos/{uid} {
      allow read: if request.auth != null && (
        request.auth.uid == uid ||
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        (
          firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'teacher' &&
          firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.schoolId ==
            firestore.get(/databases/(default)/documents/users/$(uid)).data.schoolId
        )
      );
      allow write: if request.auth != null && (
        request.auth.uid == uid ||
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        (
          firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'teacher' &&
          firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.schoolId ==
            firestore.get(/databases/(default)/documents/users/$(uid)).data.schoolId
        )
      );
    }

    // ── School logos ──────────────────────────────────────────────────────────
    // Only teachers/admins belonging to that school can upload.
    // Only signed-in users at that school, or admins, can read.
    match /school-logos/{schoolId} {
      allow read: if request.auth != null && (
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.schoolId == schoolId
      );
      allow write: if request.auth != null && (
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        (
          firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'teacher' &&
          firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.schoolId == schoolId
        )
      );
    }
  }
}
